{
  "name": "lyra-agent-ui-demo",
  "description": "A React UI framework and demo shell for coding-agent chat experiences.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "Apache-2.0",
  "keywords": [
    "agent-ui",
    "coding-agent",
    "react",
    "typescript",
    "vite",
    "chat-ui",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/petehsu/lyra-agent-ui-demo.git"
  },
  "bugs": {
    "url": "https://github.com/petehsu/lyra-agent-ui-demo/issues"
  },
  "homepage": "https://github.com/petehsu/lyra-agent-ui-demo#readme",
  "main": "./dist-lib/index.cjs",
  "module": "./dist-lib/index.js",
  "types": "./dist-lib/index.d.ts",
  "files": [
    "dist-lib",
    "INTEGRATION.md"
  ],
  "exports": {
    ".": {
      "types": "./dist-lib/index.d.ts",
      "import": "./dist-lib/index.js",
      "require": "./dist-lib/index.cjs"
    },
    "./mock": {
      "types": "./dist-lib/mock.d.ts",
      "import": "./dist-lib/mock.js",
      "require": "./dist-lib/mock.cjs"
    },
    "./styles.css": "./dist-lib/agent-chat-demo.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-react": "^1.14.0",
    "mermaid": "^11.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "vscode-icons-js": "^11.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
